{
  "name": "orderkit",
  "version": "0.1.0",
  "description": "A lightweight, animated React orderbook component",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sp00kid/orderkit.git"
  },
  "homepage": "https://github.com/sp00kid/orderkit",
  "bugs": "https://github.com/sp00kid/orderkit/issues",
  "author": "Rajul <rajulranga@gmail.com>",
  "keywords": [
    "react",
    "orderbook",
    "order-book",
    "trading",
    "prediction-market",
    "crypto",
    "exchange",
    "depth",
    "polymarket",
    "fintech"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "jsdom": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "scripts": {
    "build": "tsup && cp src/styles.css dist/styles.css",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "demo": "vite --config demo/vite.config.ts",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  }
}
